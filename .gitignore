# Archivos de Python generados localmente
__pycache__/
*.py[cod]
*$py.class

# Entornos virtuales y configuración local
.venv/
venv/
env/
.env
.env.*

# Frontend web generado con Vite
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Archivos del sistema operativo y editores
.DS_Store
.idea/
.vscode/

# Salidas generadas por la aplicación RSA
llave_publica.json
llave_privada_empleado.json
credenciales_encriptadas.json
mensaje_encriptado.txt

# Material criptográfico sensible si se agrega después
*.pem
*.key
*.crt
*.p12
